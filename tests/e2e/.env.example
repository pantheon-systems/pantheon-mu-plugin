# Base Pantheon WordPress site the harness provisions a multidev from.
TERMINUS_SITE=pantheon-mu-plugin

# Env on the base site to clone the multidev from (usually dev).
TERMINUS_SOURCE_ENV=dev

# WordPress admin credentials on the provisioned environment.
WP_USER=
WP_PASSWORD=

# Set automatically by global-setup at runtime (the multidev's base URL).
# WP_URL=

# Set HEADLESS=false to watch the browser locally.
HEADLESS=true
